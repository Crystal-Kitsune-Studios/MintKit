# config/kernel.config
# MintKit kernel defconfig for Rockchip RK3566
# Based on Linux 6.1 LTS
# Build: make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- olddefconfig

# ── Architecture ──────────────────────────────────────────────────────────────
CONFIG_ARCH_ROCKCHIP=y
CONFIG_ARM64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_HZ_250=y
CONFIG_PREEMPT=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_CPU_IDLE=y
CONFIG_ARM_CPUIDLE=y
CONFIG_CPUFREQ_DT=y
CONFIG_ARM_RK3399_DMC_DEVFREQ=y

# ── Memory ────────────────────────────────────────────────────────────────────
CONFIG_MEMORY_HOTPLUG=n
CONFIG_SWAP=y
CONFIG_ZSWAP=y
CONFIG_ZRAM=y
CONFIG_CMA=y
CONFIG_CMA_SIZE_MBYTES=64
CONFIG_DMA_CMA=y

# ── Boot / init ───────────────────────────────────────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_CMDLINE_FORCE=n
CONFIG_EFI=y
CONFIG_EFI_STUB=y

# ── Rockchip SoC drivers ──────────────────────────────────────────────────────
CONFIG_ROCKCHIP_PM_DOMAINS=y
CONFIG_ROCKCHIP_IODOMAIN=y
CONFIG_ROCKCHIP_MBOX=y
CONFIG_ROCKCHIP_THERMAL=y
CONFIG_ROCKCHIP_SARADC=y
CONFIG_ROCKCHIP_EFUSE=y
CONFIG_ROCKCHIP_OTP=y
CONFIG_MFD_RK808=y
CONFIG_REGULATOR_RK808=y
CONFIG_RTC_DRV_RK808=y

# ── Clock / pinctrl ───────────────────────────────────────────────────────────
CONFIG_COMMON_CLK_ROCKCHIP=y
CONFIG_CLK_RK3568=y
CONFIG_PINCTRL_ROCKCHIP=y
CONFIG_PINCTRL_RK3568=y
CONFIG_GPIO_ROCKCHIP=y

# ── Display (DRM/KMS — no X11 needed) ────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_ROCKCHIP_DRM_CUBIC_LUT=y
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_PANEL_MIPI_DBI=y
CONFIG_DRM_PANEL_ILITEK_ILI9341=y
CONFIG_DRM_PANEL_ST7789V=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_FB=n
CONFIG_VGA_CONSOLE=n
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_ROTATION=y
CONFIG_LOGO=n
# SDL2 with kmsdrm backend needs these:
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_KMS_FB_HELPER=y
CONFIG_DRM_GEM_CMA_HELPER=y

# ── GPU (Mali G52 on RK3566) ──────────────────────────────────────────────────
# Enable if you want OpenGLES for games; leave off for pure pygame/SDL2
# CONFIG_MALI_MIDGARD is not in mainline — needs Rockchip BSP kernel
# CONFIG_DRM_PANFROST=y   # Mainline open-source Mali driver (limited RK3566 support)

# ── Input ─────────────────────────────────────────────────────────────────────
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_JOYSTICK=y
CONFIG_JOYSTICK_XPAD=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_KEYBOARD_ADC=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_PWM_VIBRA=y
CONFIG_INPUT_UINPUT=y

# ── Audio (ALSA — no PulseAudio) ──────────────────────────────────────────────
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_ROCKCHIP=y
CONFIG_SND_SOC_ROCKCHIP_I2S=y
CONFIG_SND_SOC_ROCKCHIP_MULTICODEC=y
CONFIG_SND_SOC_RK3568_GVA=y
CONFIG_SND_SOC_ES8316=y
CONFIG_SND_SOC_ES8388=y
CONFIG_SND_SIMPLE_CARD=y
CONFIG_SND_USB_AUDIO=y
# NO PulseAudio / jack / DBus / bluetooth audio needed
CONFIG_SND_PROC_FS=n

# ── Storage (SD card + eMMC + cartridge) ──────────────────────────────────────
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_ROCKCHIP=y
CONFIG_MMC_DW_ROCKCHIP=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_OF_DWCMSHC=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_USB_STORAGE=y

# ── USB ───────────────────────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=n
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_HCD_PLATFORM=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_HCD_PLATFORM=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_OF_SIMPLE=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y

# ── WiFi ──────────────────────────────────────────────────────────────────────
CONFIG_WLAN=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_RFKILL=y
# Common RTL chips used in cheap handhelds:
CONFIG_RTL8189ES=y
CONFIG_RTL8189FS=y
CONFIG_RTL8723BS=y
CONFIG_RTL8723CS=y
# Broadcom (if using AP6xxx chip):
CONFIG_BRCMFMAC=y
CONFIG_BRCMFMAC_SDIO=y

# ── Power / charging ──────────────────────────────────────────────────────────
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY_BQ27XXX=y
CONFIG_CHARGER_BQ2515X=y
CONFIG_CHARGER_GPIO=y
CONFIG_CHARGER_BQ24190=y
CONFIG_PWM=y
CONFIG_PWM_ROCKCHIP=y

# ── I2C / SPI / UART ──────────────────────────────────────────────────────────
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_DESIGNWARE_PLATFORM=y
CONFIG_SPI=y
CONFIG_SPI_ROCKCHIP=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_SERIAL_AMBA_PL011=y

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_UTF8=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_SQUASHFS=y
CONFIG_OVERLAY_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── Networking (minimal) ──────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_DNS_RESOLVER=y
CONFIG_NLS_DEFAULT="utf8"
CONFIG_NLS_UTF8=y

# ── Security ──────────────────────────────────────────────────────────────────
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=n
CONFIG_SECURITY_APPARMOR=n
CONFIG_DEFAULT_SECURITY_DAC=y

# ── Debug (off for production) ────────────────────────────────────────────────
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_FTRACE=n
CONFIG_KGDB=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_KALLSYMS=n
CONFIG_SLUB_DEBUG=n
CONFIG_DEBUG_FS=n

# ── Size optimisations ────────────────────────────────────────────────────────
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_KERNEL_LZ4=y
CONFIG_MODULE_COMPRESS_ZSTD=y
