# mintkit.conf — MintKit build configuration
# Copy to config/mintkit.conf and edit for your build environment.

# Target board
BOARD=pi-zero-2w

# Image size in MB (512 is safe for minimal rootfs + games)
IMAGE_SIZE_MB=512

# Cross-compilation toolchain prefix
CROSS_COMPILE=aarch64-linux-gnu-
ARCH=arm64

# Raspberry Pi kernel source
KERNEL_REPO=https://github.com/raspberrypi/linux.git
KERNEL_BRANCH=rpi-6.1.y
KERNEL_DEFCONFIG=bcm2711_defconfig

# Serial console device (Pi Zero 2 W uses ttyAMA0 / serial0)
SERIAL_CONSOLE=serial0

# MintKit user credentials
MINTKIT_USER=mintkit
MINTKIT_PASS=mintkit
