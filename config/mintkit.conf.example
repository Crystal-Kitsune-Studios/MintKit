# config/mintkit.conf.example
# MintKit OS build configuration
# Copy to mintkit.conf before building: cp mintkit.conf.example mintkit.conf

# ── Board ─────────────────────────────────────────────────────────────────────
BOARD=rk3566

# ── Toolchain ─────────────────────────────────────────────────────────────────
CROSS_COMPILE=aarch64-linux-gnu-
ARCH=arm64

# ── U-Boot ────────────────────────────────────────────────────────────────────
UBOOT_VERSION=2023.10
UBOOT_DEFCONFIG=evb-rk3568_defconfig

# ── Kernel ────────────────────────────────────────────────────────────────────
KERNEL_VERSION=6.1
KERNEL_REPO=https://github.com/rockchip-linux/kernel.git
KERNEL_BRANCH=develop-5.10

# ── Rootfs ────────────────────────────────────────────────────────────────────
ROOTFS_DISTRO=jammy
ROOTFS_MIRROR=http://ports.ubuntu.com/ubuntu-ports
ROOTFS_USER=mintkit
ROOTFS_PASSWORD=mintkit
ROOTFS_HOSTNAME=pocketmint

# ── Image ─────────────────────────────────────────────────────────────────────
# Final .img size in MB (boot 128MB + rootfs; 2048 = 2GB SD minimum)
IMAGE_SIZE_MB=2048

# ── Display ───────────────────────────────────────────────────────────────────
# SDL2 video/audio drivers used at runtime
SDL_VIDEODRIVER=kmsdrm
SDL_AUDIODRIVER=alsa

# ── Serial console ────────────────────────────────────────────────────────────
SERIAL_CONSOLE=ttyS2
SERIAL_BAUD=1500000
